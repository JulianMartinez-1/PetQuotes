{
  "id": null,
  "uid": "petquotes-overview",
  "title": "PET QUOTES - Service Overview",
  "tags": ["petquotes", "observability"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Throughput req/s by endpoint",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (service, method, endpoint) (rate(petquotes_http_requests_total[5m]))",
          "legendFormat": "{{service}} {{method}} {{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error rate % by service",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * sum by (service) (rate(petquotes_http_errors_total[5m])) / clamp_min(sum by (service) (rate(petquotes_http_requests_total[5m])), 0.001)",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent" },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Average latency ms by endpoint",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "avg by (service, method, endpoint) (petquotes_http_duration_avg_ms)",
          "legendFormat": "{{service}} {{method}} {{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Max latency ms by endpoint",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "max by (service, method, endpoint) (petquotes_http_duration_max_ms)",
          "legendFormat": "{{service}} {{method}} {{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "table",
      "title": "Top endpoints by total errors",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "format": "table",
          "instant": true,
          "expr": "topk(20, sum by (service, method, endpoint) (petquotes_http_errors_total))"
        }
      ]
    }
  ]
}
