// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  CLIENT
  VETERINARY
  ADMIN
}

enum SocialProvider {
  GOOGLE
  FACEBOOK
  GITHUB
  MICROSOFT
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  RESCHEDULED
  COMPLETED
}

enum NotificationType {
  APPOINTMENT_CONFIRMED
  APPOINTMENT_CANCELLED
  APPOINTMENT_RESCHEDULED
  APPOINTMENT_REMINDER
  MEDICAL_UPDATE
  SYSTEM_ALERT
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
}

enum VeterinaryType {
  CLINIC
  INDEPENDENT
}

// ============================================================
// USERS & AUTHENTICATION
// ============================================================

model User {
  id                    String   @id @default(cuid())
  email                 String   @unique
  passwordHash          String
  fullName              String
  phone                 String?
  notificationChannel   NotificationChannel?
  role                  UserRole @default(CLIENT)
  failedLoginAttempts   Int      @default(0)
  lockedUntil           DateTime?
  emailVerified         Boolean  @default(false)
  profileImage          String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  socialAccounts        SocialAccount[]
  refreshSessions       RefreshSession[]
  ownedPets             Pet[]
  appointments          Appointment[] @relation("ClientAppointments")
  professionalProfile   Professional?
  ownedClinics          Clinic[]
  notifications         Notification[]
  veterinaryProfile     VeterinaryProfile?

  @@map("users")
}

model SocialAccount {
  id                  String         @id @default(cuid())
  userId              String
  provider            SocialProvider
  providerAccountId   String
  email               String?
  name                String?
  image               String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@unique([provider, userId])
  @@index([userId])
  @@map("social_accounts")
}

model RefreshSession {
  id          String   @id @default(cuid())
  sid         String   @unique
  userId      String
  tokenHash   String
  expiresAt   DateTime
  revokedAt   DateTime?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sid])
  @@index([userId, revokedAt])
  @@map("refresh_sessions")
}

// ============================================================
// PETS
// ============================================================

model Pet {
  id                    String   @id @default(cuid())
  ownerId               String
  name                  String?
  species               String   // dog, cat, rabbit, bird, etc.
  breed                 String?
  age                   String?  // Age in years (e.g., "3", "1.5")
  birthDate             DateTime?
  weight                Float?   // kg
  microchip             String?  @unique
  vaccinesUpToDate      Boolean  @default(false)
  bloodType             String?
  notes                 String?
  profileImage          String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  owner                 User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  appointments          Appointment[]
  medicalHistory        MedicalHistory[]
  vaccines              Vaccine[]
  medications           Medication[]

  @@index([ownerId])
  @@map("pets")
}

// ============================================================
// CLINICS & BRANCHES
// ============================================================

model Clinic {
  id                    String   @id @default(cuid())
  ownerUserId           String
  name                  String
  description           String?
  phone                 String?
  email                 String?
  website               String?
  licenseNumber         String?  @unique
  logo                  String?
  rating                Float?   @default(0)
  isVerified            Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  owner                 User     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  branches              Branch[]
  services              VeterinaryService[]
  appointments          Appointment[]
  veterinaryProfile     VeterinaryProfile?

  @@index([ownerUserId])
  @@map("clinics")
}

model Branch {
  id                    String   @id @default(cuid())
  clinicId              String
  name                  String
  city                  String
  address               String
  postalCode            String?
  phone                 String?
  latitude              Float
  longitude             Float
  openingHours          String?  // JSON string with hours
  closedDays            String?  // JSON array of closed days
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  clinic                Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  professionals         Professional[]
  appointments          Appointment[]

  @@index([clinicId])
  @@map("branches")
}

// ============================================================
// VETERINARY PROFILES
// ============================================================

model VeterinaryProfile {
  id             String          @id @default(cuid())
  userId         String          @unique
  veterinaryType VeterinaryType
  // INDEPENDENT fields
  serviceArea    String?
  homeVisits     Boolean         @default(false)
  coverageRadius Float?
  // CLINIC fields
  clinicId       String?         @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinic Clinic? @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  @@map("veterinary_profiles")
}

// ============================================================
// SERVICES
// ============================================================

model VeterinaryService {
  id                    String   @id @default(cuid())
  clinicId              String
  name                  String
  description           String?
  price                 Float
  duration              Int      // minutes
  category              String   // consultation, surgery, grooming, dental, vaccination, etc.
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  clinic                Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments          Appointment[]

  @@index([clinicId])
  @@map("veterinary_services")
}

// ============================================================
// PROFESSIONALS (Veterinarians & Staff)
// ============================================================

model Professional {
  id                    String   @id @default(cuid())
  userId                String   @unique
  branchId              String
  specialty             String
  licenseNumber         String?  @unique
  yearsOfExperience     Int?
  bio                   String?
  profileImage          String?
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch                Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  availabilities        Availability[]
  appointments          Appointment[]

  @@index([userId])
  @@index([branchId])
  @@map("professionals")
}

model Availability {
  id                    String   @id @default(cuid())
  professionalId        String
  dayOfWeek             Int      // 0-6 (Monday-Sunday)
  startTime             String   // HH:MM format
  endTime               String   // HH:MM format
  isBlocked             Boolean  @default(false)
  blockedReason         String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  professional          Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId])
  @@unique([professionalId, dayOfWeek])
  @@map("availability")
}

// ============================================================
// APPOINTMENTS
// ============================================================

model Appointment {
  id                    String            @id @default(cuid())
  clientId              String
  petId                 String
  professionalId        String?
  serviceId             String
  branchId              String?
  clinicId              String
  status                AppointmentStatus @default(PENDING)
  startTime             DateTime
  endTime               DateTime?
  notes                 String?
  idempotencyKey        String?           @unique
  cancellationReason    String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  // Relations
  client                User              @relation("ClientAppointments", fields: [clientId], references: [id], onDelete: Cascade)
  pet                   Pet               @relation(fields: [petId], references: [id], onDelete: Restrict)
  professional          Professional?     @relation(fields: [professionalId], references: [id], onDelete: Restrict)
  service               VeterinaryService @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  branch                Branch?           @relation(fields: [branchId], references: [id], onDelete: Restrict)
  clinic                Clinic            @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  medicalHistory        MedicalHistory[]

  @@index([clientId, startTime])
  @@index([petId, startTime])
  @@index([clinicId, startTime])
  @@map("appointments")
}

// ============================================================
// MEDICAL HISTORY
// ============================================================

model MedicalHistory {
  id                    String   @id @default(cuid())
  petId                 String
  appointmentId         String
  diagnosis             String?
  treatment             String?
  medicines             String?  // JSON array of medicines
  weight                Float?   // Weight at appointment time
  temperature           Float?   // Body temperature
  notes                 String?
  nextVisitDate         DateTime?
  doctorNotes           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  pet                   Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  appointment           Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@index([appointmentId])
  @@map("medical_history")
}

// ============================================================
// VACCINES
// ============================================================

model Vaccine {
  id                    String   @id @default(cuid())
  petId                 String
  name                  String   // e.g., "Rabies", "DHPP", "FVRCP"
  dateAdministered      DateTime
  expiryDate            DateTime?
  nextDueDate           DateTime?
  veterinarian          String?
  clinic                String?
  batch                 String?
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  pet                   Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@index([nextDueDate])
  @@map("vaccines")
}

// ============================================================
// MEDICATIONS
// ============================================================

model Medication {
  id                    String   @id @default(cuid())
  petId                 String
  name                  String   // e.g., "Amoxicillin", "Gabapentin"
  dosage                String   // e.g., "500mg"
  frequency             String   // e.g., "Every 8 hours", "Once daily"
  reason                String?  // e.g., "Infection", "Pain management"
  startDate             DateTime
  endDate               DateTime?
  prescribedBy          String?
  clinic                String?
  side_effects          String?
  notes                 String?
  status                String   @default("ACTIVE") // ACTIVE, COMPLETED, DISCONTINUED
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  pet                   Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@index([endDate])
  @@index([status])
  @@map("medications")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id                    String   @id @default(cuid())
  userId                String
  type                  NotificationType
  title                 String
  message               String
  data                  String?  // JSON extra data
  read                  Boolean  @default(false)
  readAt                DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}
