# Database
DATABASE_URL="postgresql://pet_quotes:pet_quotes_password@localhost:5432/pet_quotes_db"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRATION="1h"
JWT_REFRESH_EXPIRATION="7d"

# App
NODE_ENV="development"
APP_PORT=3001
APP_NAME="Pet Quotes API"

# OAuth - Google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/api/oauth/google/callback"

# OAuth - Facebook
FACEBOOK_CLIENT_ID="your-facebook-client-id"
FACEBOOK_CLIENT_SECRET="your-facebook-client-secret"
FACEBOOK_CALLBACK_URL="http://localhost:3000/api/oauth/facebook/callback"

# OAuth - GitHub
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"
GITHUB_CALLBACK_URL="http://localhost:3000/api/oauth/github/callback"

# OAuth - Microsoft
MICROSOFT_CLIENT_ID="your-microsoft-client-id"
MICROSOFT_CLIENT_SECRET="your-microsoft-client-secret"
MICROSOFT_CALLBACK_URL="http://localhost:3000/api/oauth/microsoft/callback"

# Email (Notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-email-password"

# Frontend URL
FRONTEND_URL="http://localhost:3000"

# Redis (Cache & Sessions)
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_DB=0

# Google Maps API (for clinic search)
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# Observability
PROMETHEUS_ENABLED="true"
PROMETHEUS_PORT=9090
