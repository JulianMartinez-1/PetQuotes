{
  "name": "pet-quotes-platform",
  "private": true,
  "version": "1.0.0",
  "description": "Pet Quotes Platform - Veterinary Appointment Booking System",
  "author": "Julian Martinez",
  "homepage": "https://github.com/JulianMartinez-1",
  "scripts": {
    "dev": "docker compose up --build",
    "dev:backend": "cd backend && npm run start:dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:db": "docker compose up postgres-db pgadmin -d",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "cd backend && npm run lint",
    "lint:frontend": "cd frontend && npm run lint",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd backend && npm run test",
    "test:frontend": "cd frontend && npm run test",
    "db:migrate:dev": "cd backend && npm run prisma:migrate:dev",
    "db:migrate:deploy": "cd backend && npm run prisma:migrate:deploy",
    "db:push": "cd backend && npm run prisma:push",
    "db:seed": "cd backend && npm run prisma:seed",
    "db:studio": "cd backend && npm run prisma:studio",
    "db:backup": "powershell -ExecutionPolicy Bypass -File ./scripts/db-backup.ps1",
    "db:restore": "powershell -ExecutionPolicy Bypass -File ./scripts/db-restore.ps1",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:clean": "docker compose down -v"
  },
  "devDependencies": {
    "@types/node": "^22.5.4"
  },
  "overrides": {
    "typescript": "5.4.5",
    "eslint": "8.57.0"
  }
}
