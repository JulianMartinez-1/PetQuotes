# Analytics Service — Environment Variables
# Copy to .env and fill in real values

# ── Database (read-only user recommended for production) ──────
ANALYTICS_DB_URL=postgresql://pet_quotes_ro:readonly_password@postgres-db:5432/pet_quotes_db
# For development you can use the same user as the backend, but create a
# dedicated read-only user in production:
#   CREATE USER pet_quotes_ro WITH PASSWORD 'readonly_password';
#   GRANT CONNECT ON DATABASE pet_quotes_db TO pet_quotes_ro;
#   GRANT USAGE ON SCHEMA public TO pet_quotes_ro;
#   GRANT SELECT ON ALL TABLES IN SCHEMA public TO pet_quotes_ro;

# ── JWT (must match the backend's JWT_SECRET exactly) ─────────
JWT_SECRET=super-access-secret
JWT_ALGORITHM=HS256

# ── Service ───────────────────────────────────────────────────
ANALYTICS_PORT=3009
LOG_LEVEL=info
