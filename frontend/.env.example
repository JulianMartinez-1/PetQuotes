# ============================================================
# Pet Quotes — Frontend Environment Variables
# Copy to .env.local and fill in real values before running.
#
# IMPORTANT: Variables prefixed NEXT_PUBLIC_ are baked into
# the JavaScript bundle at BUILD time. In Docker, they must be
# passed as build ARGs (see docker-compose.yml build.args).
# Server-only variables (no prefix) are safe at runtime only.
# ============================================================

# ── Server-only (not exposed to browser) ─────────────────────

# Internal URL of the NestJS backend (Docker service name in prod)
# Production: http://backend:3001
# Local dev:  http://localhost:3001
API_BASE_URL="http://localhost:3001"

# JWT secret — must match JWT_SECRET on the backend exactly
JWT_ACCESS_SECRET="change-this-to-a-long-random-secret"

# Proxy timeout in milliseconds for server-side API calls
API_PROXY_TIMEOUT_MS=8000

# Ollama AI chat (optional feature — leave empty to disable)
OLLAMA_API_URL="http://localhost:11434"
OLLAMA_MODEL="llama3"

# ── Public (baked into the browser bundle at build time) ──────

# Public base URL of the NestJS backend (used by browser for direct API calls)
# Production: https://api.petquotes.online
# Local dev:  http://localhost:3001
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Request timeout for client-side API calls (milliseconds)
NEXT_PUBLIC_API_TIMEOUT_MS=10000

# Google Maps API key — restrict to petquotes.online in Google Cloud Console
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# Google reCAPTCHA v2 — get keys at https://www.google.com/recaptcha/admin
# Site key is public (browser); secret key must stay server-side only
NEXT_PUBLIC_RECAPTCHA_SITE_KEY="your-recaptcha-site-key"
RECAPTCHA_SECRET_KEY="your-recaptcha-secret-key"
