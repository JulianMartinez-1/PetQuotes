NODE_ENV=development
ALLOW_DB_PUSH=true
CORS_ORIGINS=http://localhost:3000
POSTGRES_ADMIN_PASSWORD=postgres
AUTH_DB_APP_PASSWORD=auth_app_dev_change_me
APPOINTMENT_DB_APP_PASSWORD=appointment_app_dev_change_me

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
API_BASE_URL=http://api-gateway:3001
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Gateway
GATEWAY_PORT=3001
AUTH_SERVICE_URL=http://auth-service:3002
APPOINTMENT_SERVICE_URL=http://appointment-service:3005

# Auth service
AUTH_PORT=3002
AUTH_DATABASE_URL=postgresql://auth_app:auth_app_dev_change_me@auth-db:5432/auth_db?schema=public
JWT_ACCESS_SECRET=super-access-secret
JWT_REFRESH_SECRET=super-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOGIN_LOCK_MINUTES=15
OAUTH_STATE_SECRET=super-oauth-state-secret
OAUTH_GOOGLE_CLIENT_ID=your-google-client-id
OAUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret
OAUTH_FACEBOOK_CLIENT_ID=your-facebook-client-id
OAUTH_FACEBOOK_CLIENT_SECRET=your-facebook-client-secret
OAUTH_FACEBOOK_SCOPE=public_profile
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=

# Appointment service
APPOINTMENT_PORT=3005
APPOINTMENT_DATABASE_URL=postgresql://appointment_app:appointment_app_dev_change_me@appointment-db:5432/appointment_db?schema=public
REDIS_URL=redis://redis:6379
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
ELASTICSEARCH_URL=http://elasticsearch:9200
SERVICE_HTTP_TIMEOUT_MS=8000
API_PROXY_TIMEOUT_MS=8000

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@petquotes.local
PGADMIN_DEFAULT_PASSWORD=admin
