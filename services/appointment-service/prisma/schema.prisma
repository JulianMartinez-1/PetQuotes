generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("APPOINTMENT_DATABASE_URL")
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  RESCHEDULED
}

model Appointment {
  id             String            @id @default(cuid())
  clientId       String
  petId          String
  pet            Pet               @relation(fields: [petId], references: [id], onDelete: Restrict)
  veterinarianId String
  serviceId      String
  branchId       String
  idempotencyKey String?           @unique
  status         AppointmentStatus @default(PENDING)
  startsAt       DateTime
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([clientId, startsAt])
  @@index([veterinarianId, startsAt])
  @@index([petId, startsAt])
  @@unique([veterinarianId, startsAt])
}

model Pet {
  id           String        @id
  ownerId      String
  name         String
  species      String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]

  @@index([ownerId])
}
